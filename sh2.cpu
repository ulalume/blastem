sh2_interrupt
	if delay_slot
		#interrupts not accepted here
	else
		if cycles >=U int_cycle
			cycles 1
			r15 -= 4
			sh2_collect_sr
			sh2_write32 r15 sr
			cycles 1
			r15 -= 4
			sh2_write32 r15 pc
			sh2_vector_read int_vector
